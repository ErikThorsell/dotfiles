# i3status configuration file.
# see "man i3status" for documentation.

# It is important that this file is edited as UTF-8.
# The following line should contain a sharp s:
# ß
# If the above line is not correctly displayed, fix your editor first!

general {
        colors = true
        interval = 1 
}

order += "disk /"
order += "disk /home"
order += "ethernet enp7s0"
order += "cpu_usage"
order += "cpu_temperature 0"
#order += "volume master"
order += "tztime local"

ethernet enp7s0 {
        # if you use %speed, i3status requires root privileges
        format_up = "Ethernet IP: %ip"
        format_down = "E: down"
}

tztime local {
        format = "%Y-%m-%d %H:%M:%S"
}

cpu_usage {
        format = "L: %usage"
}

disk "/" {
        format = "/ %avail"
}

disk "/home" {
	format = "/home %avail"
}

volume master {
        format = "♪: %volume"
        device = "default"
        mixer = "Master"
        mixer_idx = 0
}
cpu_temperature 0 {
	format = "T: %degrees °C"
