# Global properties
separator_block_width=15

[weather]
label=Weather
command=/home/erik/.config/i3blocks/iconweather.sh "EUR|SE|41279|GOTHENBURG"
interval=300
min_width=30
color=#1aa12a
separator=true

[volume]
label=VOL
#label=♪
instance=Master
#instance=PCM
command=/home/erik/.config/i3blocks/volume.sh
interval=1
signal=10
color=#a9169c

[memory]
label=RAM
command=/home/erik/.config/i3blocks/memory
interval=30
color=#7a87ec
separator=false

[disk-root]
label=Disk
command=/home/erik/.config/i3blocks/disk /
interval=30
color=#7a87ec
separator=true

[wireless]
label=W
instance=wlp3s0
command=/home/erik/.config/i3blocks/network wlp3s0
color=#00FF00
interval=10

[ethernet]
label=E
instance=enp0s25
command=/home/erik/.config/i3blocks/network enp0s25
color=#00FF00
interval=10

