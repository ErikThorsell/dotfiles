#Media keys

# Media player controls (GIU applications)
bindsym XF86AudioPlay exec playerctl play-pause
bindsym XF86AudioNext exec playerctl next
bindsym XF86AudioPrev exec playerctl previous

# Media player controls (MPC)
bindsym Mod4+F4 exec mpc toggle
bindsym Mod4+F6 exec mpc next
bindsym Mod4+F5 exec mpc prev

# Audio controls
bindsym XF86AudioLowerVolume exec pactl set-sink-volume 1 -5%
bindsym XF86AudioRaiseVolume exec pactl set-sink-volume 1 +5%
bindsym XF86AudioMute exec pactl set-sink-mute 1 toggle # mute sound

# Brightness Controls
bindsym XF86MonBrightnessUp exec xbacklight -inc 5
bindsym XF86MonBrightnessDown exec xbacklight -dec 5

# Trackpad
bindsym XF86Explorer exec -no-startup-id synclient TouchpadOff=$(synclient -l | grep -c 'TouchpadOff.*=.*0')

